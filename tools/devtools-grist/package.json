{
  "name": "@aot-dep-badi/devtools-grist",
  "type": "module",
  "version": "0.1.0",
  "description": "A starter for creating a TypeScript package.",
  "author": "Vincent Blain <vincent.blain@ac-orleans-tours.fr>",
  "license": "MIT",
  "homepage": "https://github.com/AOT-DEP-BADI/grist-custom-widget-vite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AOT-DEP-BADI/grist-custom-widget-vite",
    "directory": "tools/devtools-grist"
  },
  "bugs": {
    "url": "https://github.com/AOT-DEP-BADI/grist-custom-widget-vite/issues"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bin": {
    "devtools-grist": "./dist/cli.mjs"
  },
  "exports": {
    "./cli": "./dist/cli.mjs",
    "./vite": "./dist/vite/plugins/grist-manifest.mjs",
    "./package.json": "./package.json",
    "./docker-compose.yml": "./dist/docker-compose.yml"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:bin": "node ./dist/cli.mjs",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "archive": "pnpm run build && pnpm pack --pack-destination ../../tests/e2e/pack/",
    "prebuild": "pnpm run typecheck",
    "prepublishOnly": "pnpm run typecheck && vitest run && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "execa": "^9.6.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "i18next": "^26.2.0"
  }
}